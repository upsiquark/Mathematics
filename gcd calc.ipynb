    "def gcd_calc(a,b):\n",
    "    if (a < b):\n",
    "        c = b//a \n",
    "        d = b%a\n",
    "        \n",
    "        while (d != 0):\n",
    "            return(gcd_calc(a,d))\n",
    "        return(a)\n",
    "        \n",
    "    else:\n",
    "        c = a//b \n",
    "        d = a%b\n",
    "        while(d != 0):\n",
    "            return(gcd_calc(b,d))\n",
    "        return(b)"
   ]
  }
